{
  "name": "intern-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "backend": "cd backend && py app.py",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:full": "concurrently \"npm run backend\" \"npm run dev\" \"wait-on tcp:localhost:5055 http://localhost:5174 && electron .\""
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@types/file-saver": "^2.0.7",
    "docxtemplater": "^3.69.0",
    "file-saver": "^2.0.5",
    "html2pdf.js": "^0.14.0",
    "pizzip": "^3.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^34.0.2",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^8.0.2"
  },
  "main": "main.cjs"
}
